{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "jsx": "preserve",
        "jsxImportSource": "solid-js",
        "allowJs": true,
        "strict": true,
        "noEmit": true,
        "types": ["vinxi/types/client", "vitest/globals"],
        "isolatedModules": true,
        "skipLibCheck": true,
        "paths": {
            "~/*": ["./src/*"]
        }
    },
    "include": ["src", "tests"]
}
