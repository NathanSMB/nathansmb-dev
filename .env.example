# Required
NETLIFY_DATABASE_URL=<some_db_url>
BETTER_AUTH_URL=<app_url> # Local: http://localhost:3000
BETTER_AUTH_SECRET=<some_secret> # A secret value used for encryption and hashing. It must be at least 32 characters and generated with high entropy. You can use `openssl rand -base64 32` to generate one.

# Optional
