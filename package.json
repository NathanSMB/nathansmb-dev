{
    "name": "example-basic",
    "type": "module",
    "scripts": {
        "predev": "bun run prebuild",
        "dev": "vinxi dev",
        "prebuild": "mkdir -p ./src/database/schemas && touch ./src/database/schemas/auth.ts && bun run generate-auth-schema -y",
        "build": "vinxi build",
        "start": "vinxi start",
        "version": "vinxi version",
        "generate-auth-schema": "better-auth generate --config ./src/auth/core.ts --output ./src/database/schemas/auth.ts",
        "push-schemas": "bunx drizzle-kit push",
        "lint": "eslint src/",
        "format": "prettier --write src/",
        "test": "vitest run --passWithNoTests",
        "typecheck": "tsc --noEmit -p tsconfig.json"
    },
    "dependencies": {
        "@neondatabase/serverless": "^1.0.2",
        "@solidjs/meta": "^0.29.4",
        "@solidjs/router": "^0.15.0",
        "@solidjs/start": "^1.1.0",
        "@tanstack/solid-table": "^8.21.3",
        "@tiptap/core": "^3.20.1",
        "@tiptap/extension-image": "^3.20.1",
        "@tiptap/extension-placeholder": "^3.20.1",
        "@tiptap/pm": "^3.20.1",
        "@tiptap/starter-kit": "^3.20.1",
        "better-auth": "^1.4.20",
        "dotenv": "^17.3.1",
        "drizzle-orm": "^0.45.1",
        "marked": "^17.0.4",
        "solid-icons": "^1.2.0",
        "solid-js": "^1.9.5",
        "three": "^0.183.2",
        "tiptap-markdown": "^0.9.0",
        "vinxi": "^0.5.7"
    },
    "engines": {
        "node": ">=22"
    },
    "devDependencies": {
        "@better-auth/cli": "^1.4.20",
        "@solidjs/testing-library": "^0.8.10",
        "@types/marked": "^6.0.0",
        "@types/three": "^0.183.1",
        "drizzle-kit": "^0.31.9",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-solid": "^0.14.5",
        "jsdom": "^28.1.0",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vite-plugin-solid": "^2.11.10",
        "vitest": "^4.0.18"
    }
}
